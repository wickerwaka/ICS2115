# ICS2115 IRQ system test
# Programs voice 0 as a one-shot oscillator with IRQ enabled.
# Boundary cross fires osc IRQ → host_irq asserts → IRQV read returns voice 0 → auto-clear deasserts IRQ.

# Select voice 0
write 0x4F 0x0000

# Set active_osc = 31 (all 32 voices active for scanning)
write 0x0E 0x1F00

# Set maximum frequency so boundary is reached on first sample tick
# osc_fc = 0xFFFF → step = 0x3FFFC per sample tick
write 0x01 0xFFFF

# Set oscillator accumulator to start of ROM (position 0)
write 0x0A 0x0000
write 0x0B 0x0000

# Set sample bank address = 0
write 0x11 0x0000

# Set loop start = 0
write 0x02 0x0000
write 0x03 0x0000

# Set loop end = byte address 4 (20.9 format: 4 << 9 = 0x800)
# osc_end[28:21] = 0x00, [20:13] = 0x00, [12:5] = 0x10, [4:0] = 0x00
# Actually: 0x800 = 0b 0_00000000_00000100_000000000
# Bits [28:21]=0x00, [20:13]=0x00, [12:9]=0x1, [8:5]=0x0
# Reg 0x04: port3 = osc_end[28:21]=0x00, port2 = osc_end[20:13]=0x00
write 0x04 0x0000
# Reg 0x05: port3 = osc_end[12:5] = 0x10
write 0x05 0x1000

# Set volume to maximum
write 0x09 0xFFFF

# Set pan to center
write 0x0C 0x7F00

# Set osc_conf: IRQ enabled (bit 5), no loop, not stopped
# 0x20 = bit 5 set = IRQ enable
write 0x00 0x2000

# Set vol_ctrl: done=1 to prevent volume envelope from running
write 0x0D 0x0100

# Key-on voice 0 (write 0x00 to osc_ctl clears stop, sets state_on)
write 0x10 0x0000

# Wait for IRQ — should fire within a few sample ticks
wait_irq 5000000

# Read IRQV (register 0x0F) — should show voice 0 with osc IRQ
# Expected: bit 7 clear (osc source), bits 4:0 = 0 (voice 0), bits 6:5 = 11
# So result = 0b_0110_0000 = 0x60
# In reg_read_data[15:8] format → 0x6000
read 0x0F

# Now verify IRQ has deasserted by reading port 0 status
# After IRQV read auto-cleared the pending bit, host_irq should be 0
# Port 0 bit 7 should be 0 (no IRQ active)
# We use the UNTIL command to poll port 0 for bit 7 == 0
# But first, let's just wait a few cycles for the clear to propagate
wait 100

# Read IRQV again — should now be 0xFF (no pending)
read 0x0F
