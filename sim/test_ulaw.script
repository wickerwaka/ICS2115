# ICS2115 µ-law sample playback test
# Programs voice 0 to play a µ-law encoded sine wave from ROM.
# ROM layout: µ-law sine at byte 0x1400 (1024 samples)
#
# osc_conf: LOOP (bit 3) + ULAW (bit 0) = 0x09
# Verifies: osc_conf readback, nonzero audio output
#
# Address mapping: RTL uses 29-bit acc with 20.9 fixed-point.
# byte_addr = acc[28:9]. To address byte B: acc = B << 9.

# Select voice 0
write 0x4F 0x0000

# Set active_osc = 31
write 0x0E 0x1F00

# Frequency counter: fc=0x6000 (~387 Hz)
write 0x01 0x6000

# Oscillator accumulator = byte 0x1400 (start of µ-law region)
# acc = 0x1400 << 9 = 0x00280000
# reg 0x0A: [28:21]=0x01, [20:13]=0x40 → 0x0140
# reg 0x0B: [12:5]=0x00, [4:0]=0x00 → 0x0000
write 0x0A 0x0140
write 0x0B 0x0000

# Sample bank = 0
write 0x11 0x0000

# Loop start = byte 0x1400
# acc = 0x1400 << 9 = 0x00280000
write 0x02 0x0140
write 0x03 0x0000

# Loop end = byte 0x17FF (last µ-law sample)
# acc = 0x17FF << 9 = 0x002FFE00
# reg 0x04: [28:21]=0x01, [20:13]=0x7F → 0x017F
# reg 0x05: [12:5]=0xF0, [4:0]=0x00 → 0xF000
write 0x04 0x017F
write 0x05 0xF000

# Volume max
write 0x09 0xFFFF

# Pan center
write 0x0C 0x7F00

# osc_conf: loop=1 (bit 3) + ulaw=1 (bit 0) = 0x09
write 0x00 0x0900

# vol_ctrl: done=1
write 0x0D 0x0100

# Keyon voice 0
write 0x10 0x0000

# Wait for playback
wait 2000000

# Verify osc_conf readback has ulaw and loop bits set
expect 0x00 0x0900 0x0900

# Let it play more for WAV output
wait 38000000
