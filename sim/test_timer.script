# ICS2115 Timer IRQ test
# Programs timer 0 with preset=10, scale=0 → period=176 ce ticks.
# Verifies: IRQ fires, status shows pending, preset read clears IRQ,
# auto-reload fires again.

# Enable timer 0 IRQ (bit 0 of irq_enabled)
write 0x4A 0x0001

# Set timer 0 preset = 10 (register 0x40, low byte write)
write 0x40 0x000A

# Set timer 0 prescale = 0 (register 0x42, low byte write)
# period = ((0 & 0x1F)+1) * (10+1) << (4+(0>>5)) = 1*11 << 4 = 176
write 0x42 0x0000

# Wait for timer 0 to fire
wait_irq 1000000

# Read timer status (0x43) — should show timer 0 pending (bit 0 set)
expect 0x43 0x0001

# Read timer 0 preset (0x40) — should return 0x000A AND clear timer 0 IRQ
expect 0x40 0x000A

# Read timer status again — should show timer 0 cleared (bit 0 = 0)
expect 0x43 0x0000

# Wait for auto-reload to fire again
wait_irq 1000000

# Read timer status — should show timer 0 pending again
expect 0x43 0x0001
