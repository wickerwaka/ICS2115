# ICS2115 8-bit sample playback test
# Programs voice 0 to play an 8-bit signed sine wave from ROM.
# ROM layout: 8-bit sine at byte 0x1000 (1024 samples)
#
# osc_conf: LOOP (bit 3) + EIGHTBIT (bit 2) = 0x0C
# Verifies: osc_conf readback, nonzero audio output
#
# Address mapping: RTL uses 29-bit acc with 20.9 fixed-point.
# byte_addr = acc[28:9]. To address byte B: acc = B << 9.
# Register write mapping:
#   reg_hi port3 (high byte) → acc[28:21]
#   reg_hi port2 (low byte)  → acc[20:13]
#   reg_lo port3 (high byte) → acc[12:5]
#   reg_lo port2 (low byte)  → acc[4:0] from din[7:3]

# Select voice 0
write 0x4F 0x0000

# Set active_osc = 31
write 0x0E 0x1F00

# Frequency counter: fc=0x6000 (~387 Hz)
write 0x01 0x6000

# Oscillator accumulator = byte 0x1000 (start of 8-bit region)
# acc = 0x1000 << 9 = 0x00200000
# reg 0x0A: [28:21]=0x01, [20:13]=0x00 → 0x0100
# reg 0x0B: [12:5]=0x00, [4:0]=0x00 → 0x0000
write 0x0A 0x0100
write 0x0B 0x0000

# Sample bank = 0
write 0x11 0x0000

# Loop start = byte 0x1000
# acc = 0x1000 << 9 = 0x00200000
# reg 0x02: 0x0100, reg 0x03: 0x0000
write 0x02 0x0100
write 0x03 0x0000

# Loop end = byte 0x13FF (last 8-bit sample)
# acc = 0x13FF << 9 = 0x0027FE00
# reg 0x04: [28:21]=0x01, [20:13]=0x3F → 0x013F
# reg 0x05: [12:5]=0xF0, [4:0]=0x00 → 0xF000
write 0x04 0x013F
write 0x05 0xF000

# Volume max
write 0x09 0xFFFF

# Pan center
write 0x0C 0x7F00

# osc_conf: loop=1 (bit 3) + eightbit=1 (bit 2) = 0x0C
write 0x00 0x0C00

# vol_ctrl: done=1
write 0x0D 0x0100

# Keyon voice 0
write 0x10 0x0000

# Wait for playback
wait 2000000

# Verify osc_conf readback has eightbit and loop bits set
expect 0x00 0x0C00 0x0C00

# Let it play more for WAV output
wait 38000000
