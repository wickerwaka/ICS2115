# ICS2115 Volume Envelope Test — Looping Ramp
# Programs voice 0 to play a sine wave with the volume envelope in loop mode.
# The envelope ramps between vol_start and vol_end, wrapping around
# indefinitely. The voice should never stop because done is never set.
#
# Expected behavior:
#   - Volume ramps from vol_start (0x40 << 18) to vol_end (0xFF << 18)
#   - When vol_end is reached, envelope wraps back to vol_start
#   - Voice plays continuously — should produce >50000 audio frames
#
# vol_incr = 0x3F: rate=0 (every tick), magnitude=63 (max speed)

# Select voice 0
write 0x4F 0x0000

# Set active_osc = 31 (all 32 voices active)
write 0x0E 0x1F00

# Set frequency counter: fc = 0x6000 → ~387 Hz at 33075 Hz
write 0x01 0x6000

# Set oscillator accumulator = 0 (start of ROM)
write 0x0A 0x0000
write 0x0B 0x0000

# Set sample bank address = 0
write 0x11 0x0000

# Set loop start = 0
write 0x02 0x0000
write 0x03 0x0000

# Set loop end = byte address 2046 (last sample), same as test.script
write 0x04 0x007F
write 0x05 0xE000

# Set osc_conf: loop=1 (bit 3) — forward loop mode
write 0x00 0x0800

# --- Volume envelope setup (looping) ---

# vol_incr = 0x3F: rate=0 (every tick), magnitude=63 (max)
write 0x06 0x3F00

# vol_start = 0x40 << 18 (audible level, ~25% of range)
# Port 2 write: vol_start <= {low_byte, 18'd0}
write 0x07 0x0040

# vol_end = 0xFF << 18 (near-maximum)
# Port 2 write: vol_end <= {low_byte, 18'd0}
write 0x08 0x00FF

# vol_acc = 0x40 << 18 (start at vol_start level)
# Port 3: vol_acc[25:18] = 0x40
# Port 2: vol_acc[17:10] = 0x00
write 0x09 0x4000

# vol_ctrl = 0x08: loop=1 (bit 3), increasing (invert=0), not done, not stopped
# Port 3 write: vol_ctrl[6:0] <= high byte
write 0x0D 0x0800

# Pan = center (0x7F)
write 0x0C 0x7F00

# Keyon
write 0x10 0x0000

# Wait for plenty of audio samples — voice should keep playing
# 80M sys clocks ≈ 50k+ audio samples
wait 80000000
