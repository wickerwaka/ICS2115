# ICS2115 Multi-Voice Mix Test
# Programs 2 voices at center pan with different waveforms.
# Voice 0: sine wave from ROM 0x0000, fc=0x6000 (~387 Hz)
# Voice 1: square wave from ROM 0x0800, fc=0x4000 (~258 Hz)
# Both at maximum volume, vol_ctrl.done=1, pan=center (0x7F)
#
# ROM: multi_test.rom (4096 bytes)
#   0x0000-0x07FF: 1024-sample sine wave
#   0x0800-0x0FFF: 1024-sample square wave

# ---- Voice 0: Sine wave ----
# Select voice 0
write 0x4F 0x0000

# Set active_osc = 31 (all 32 voices)
write 0x0E 0x1F00

# Frequency counter: fc=0x6000 → ~387 Hz at 33075 Hz
write 0x01 0x6000

# Oscillator accumulator = 0 (start of ROM)
write 0x0A 0x0000
write 0x0B 0x0000

# Sample bank = 0
write 0x11 0x0000

# Loop start = 0
write 0x02 0x0000
write 0x03 0x0000

# Loop end = byte addr 2046 (last sample in sine region)
# 20.9: 2046 << 9 = 0x000FFC00
# [28:21]=0x00, [20:13]=0x7F, [12:5]=0xE0
write 0x04 0x007F
write 0x05 0xE000

# Volume max: vol_acc[25:18]=0xFF, vol_acc[17:10]=0xFF
write 0x09 0xFFFF

# Pan = center (0x7F)
write 0x0C 0x7F00

# osc_conf: loop=1 (bit 3)
write 0x00 0x0800

# vol_ctrl: done=1 (bit 0) — no envelope updates
write 0x0D 0x0100

# Keyon voice 0
write 0x10 0x0000

# ---- Voice 1: Square wave ----
# Select voice 1
write 0x4F 0x0001

# Frequency counter: fc=0x4000 → ~258 Hz at 33075 Hz
write 0x01 0x4000

# Oscillator accumulator = byte addr 2048 (0x800)
# 20.9: 2048 << 9 = 0x00100000
# [28:21]=0x00, [20:13]=0x80, [12:5]=0x00, [4:0]=0x00
write 0x0A 0x0080
write 0x0B 0x0000

# Sample bank = 0
write 0x11 0x0000

# Loop start = byte addr 2048
# [28:21]=0x00, [20:13]=0x80, [12:5]=0x00
write 0x02 0x0080
write 0x03 0x0000

# Loop end = byte addr 4094 (last sample in square region)
# 20.9: 4094 << 9 = 0x001FFC00
# [28:21]=0x00, [20:13]=0xFF, [12:5]=0xE0
write 0x04 0x00FF
write 0x05 0xE000

# Volume max
write 0x09 0xFFFF

# Pan = center (0x7F)
write 0x0C 0x7F00

# osc_conf: loop=1 (bit 3)
write 0x00 0x0800

# vol_ctrl: done=1 (bit 0)
write 0x0D 0x0100

# Keyon voice 1
write 0x10 0x0000

# Wait 80M cycles (~50k+ audio frames)
wait 80000000
